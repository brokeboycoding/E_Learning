<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"] - Web Học Trực Tuyến</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.plyr.io/3.7.8/plyr.css" />

   
    <style>
        /* ======= Sidebar ======= */
        .sidebar {
            width: 250px;
            height: 100vh;
            position: fixed;
            top: 56px;
            left: 0;
            background-color: #262020;
            padding-top: 20px;
            transition: transform 0.3s ease-in-out;
            box-shadow: 2px 0 5px rgba(0, 0, 0, 0.1);
            z-index: 1000;
        }

            .sidebar.hidden {
                transform: translateX(-250px);
            }

            .sidebar a {
                display: block;
                padding: 10px;
                color: #f0f3f6;
                text-decoration: none;
            }

                .sidebar a:hover {
                    background-color: #39ba0e;
                }

        nav a:hover {
            background-color: #f0f0f0;
            border-radius: 4px;
        }

        /* ======= Content ======= */
        .content {
            margin-left: 250px;
            transition: margin-left 0.3s ease-in-out;
            padding: 20px;
            flex: 1;
        }

            .content.full {
                margin-left: 0;
            }

        /* ======= Navbar ======= */
        .navbar-custom {
            background-color: #000;
        }

            .navbar-custom .nav-link,
            .navbar-custom .navbar-brand {
                color: rgb(255, 255, 255);
            }

                .navbar-custom .nav-link:hover {
                    color: #ddd;
                }

        /* ======= Toggle Button ======= */
        .toggle-btn {
            border: none;
            background: transparent;
            font-size: 24px;
            cursor: pointer;
            transition: transform 0.3s ease;
        }

            .toggle-btn.rotated {
                transform: rotate(180deg);
            }

        /* ======= Footer ======= */
        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        footer {
            background-color: #212529;
            color: rgb(96, 77, 138);
            text-align: center;
            padding: 15px;
        }

        .navbar .dropdown-menu {
            font-family: Arial, sans-serif;
            font-size: 14px;
        }
    </style>
</head>

<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-custom">
        <div class="container-fluid">
            <button class="toggle-btn text-white me-3" id="toggleSidebar">☰</button>
            <a class="navbar-brand" href="/">📚 Web Học Trực Tuyến</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Courses">Khóa học</a></li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Lesson" asp-action="MyCourse">Khóa học của tôi</a>
                    </li>

                </ul>

                <ul class="navbar-nav ms-3">
                    @* <li class="nav-item"><a class="nav-link" href="/Cart">🛒 Giỏ hàng</a></li> *@
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="btn btn-primary" href="@Url.Action("ManageAccounts","ManageAccount", new { area = "Admin" })">
                                🔑 Quản lý tài khoản
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-primary" asp-area="Admin" asp-controller="Course" asp-action="Index">
                                🔑 Quản lý khoá học
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-primary" asp-area="Admin" asp-controller="Course" asp-action="ManageAll">
                                Quản lý nội dung khóa học
                            </a>
                        </li>

						<li class="nav-item">
							<a class="btn btn-primary" asp-area="Admin" asp-controller="Course" asp-action="Create">
								Tạo khóa học
							</a>
						</li>
					}
						
				
                    @{
                        // Giả sử bạn có hệ thống phân quyền theo role, ví dụ role "Teacher"
                        bool isTeacher = User.IsInRole("Teacher");
                    }
                    @if (isTeacher)
                    {
                        <li class="nav-item">
                            <a class="btn btn-primary" asp-area="teacher" asp-controller="Course" asp-action="Index">
                                🔑 Quản lý khoá học
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-primary" asp-area="teacher" asp-controller="Course" asp-action="ManageAll">
                                Quản lý nội dung khóa học
                            </a>
                        </li>
                        <a asp-area="Teacher" asp-controller="Course" asp-action="Create" class="btn btn-primary">Tạo khóa học</a>

                    }

                    <partial name="_LoginPartial" />
                </ul>
               
            </div>
        </div>
    </nav>
    @RenderSection("Scripts", required: false)

    <!-- Sidebar -->
    <!-- Toggle Button -->
    

    <div class="d-flex">
        <!-- Sidebar -->
        <nav id="sidebar" class="bg-light border-end p-3" style="width: 280px; min-height: 100vh; overflow-y: auto;">
            <h6 class="text-uppercase fw-bold">By goal</h6>
            <ul class="list-unstyled mb-4">
                <li><a href="#" class="text-decoration-none d-block py-1">Take a course</a></li>
                <li><a href="#" class="text-decoration-none d-block py-1">Earn a certificate</a></li>
                <li><a href="#" class="text-decoration-none d-block py-1">Earn a degree</a></li>
            </ul>

            <h6 class="text-uppercase fw-bold">By topic</h6>
            <ul class="list-unstyled mb-4">
                <li><a href="#" class="text-decoration-none d-block py-1">Artificial Intelligence</a></li>
                <li><a href="#" class="text-decoration-none d-block py-1">Data Science</a></li>
                <li><a href="#" class="text-decoration-none d-block py-1">Finance</a></li>
                <li><a href="#" class="text-decoration-none d-block py-1">Cybersecurity</a></li>
                <li><a href="#" class="text-decoration-none d-block py-1">Computer Science</a></li>
                <li><a href="#" class="text-decoration-none d-block py-1">View all topics</a></li>
            </ul>

            <h6 class="text-uppercase fw-bold">More</h6>
            <ul class="list-unstyled">
                <li><a href="#" class="text-decoration-none d-block py-1">Career resources</a></li>
                <li><a href="#" class="text-decoration-none d-block py-1">Schools & Partners</a></li>
            </ul>
        </nav>

        <!-- Main content -->
        <div class="flex-grow-1 p-4">
            @RenderBody()
        </div>
    </div>



    <!-- Nội dung chính -->
    <div id="content" class="content">
        <div class="container mt-5 pt-4">
            @RenderBody()
        </div>
    </div>

    <!-- Footer -->
   <div class="footer-warpper">
       <div class="footer container py-3">
           <div class="footer-logo-wapper flex"> 
               <div>
                    <img src="https://d10g66pf9vjy7h.cloudfront.net/media/home-page-resources/footer-logo.png" alt="logo" class="footer-logo" />
               </div>
                <div class="footer-language-selector-wrapper"></div>
           </div>
           <div class="info-rows flex">
                <div class="info">
                    <div class="title">Thông tin</div>
                    <div class="with-icon">
                        <span class="pgn__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" focusable="false" aria-hidden="true"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8h5Z" fill="currentColor"></path></svg></span>TRUNG TÂM DẠY HỌC SỐ - HUTECH
                        </div>
                    <div class="with-icon">
                        <span class="pgn__icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" role="img" focusable="false" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 0 1 0-5 2.5 2.5 0 0 1 0 5z" fill="currentColor"></path></svg></span><a href="https://maps.app.goo.gl/Z2LgC4AzB9E84wL78">475A Điện Biên Phủ, P.25, Q.Bình Thạnh, TP.HCM</a>
                        </div>
                    <div class="with-icon"><span class="pgn__icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" role="img" focusable="false" aria-hidden="true"><path d="m21 15.46-5.27-.61-2.52 2.52a15.045 15.045 0 0 1-6.59-6.59l2.53-2.53L8.54 3H3.03C2.45 13.18 10.82 21.55 21 20.97v-5.51z" fill="currentColor"></path></svg></span><a href="tel:+8402854499998">0838 308 440</a>
                        </div>
                    <div class="with-icon"><span class="pgn__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" focusable="false" aria-hidden="true"><path d="M22 4H2v16h20V4Zm-2 4-8 5-8-5V6l8 5 8-5v2Z" fill="currentColor"></path></svg></span> <a href="mailto: thienhoangpn8@gmail.com">thienhoangpn8@gmail.com</a>
                        </div>
                </div>
                <div class="connect">
                    <div class="title"> kết Nối </div>

                </div>
           </div>
           <div class="text-right pt-3 pl-3 pr-3">
                "© 2025 HPK eLearning."
           </div>
       </div>
   </div>

    <!-- JavaScript 
    <script>
        function toggleSidebar() {
            var sidebar = document.getElementById("sidebar");
            var content = document.getElementById("content");
            var toggleBtn = document.getElementById("toggleBtn");

            sidebar.classList.toggle("hidden");
            content.classList.toggle("full");
            toggleBtn.classList.toggle("rotated");
        }
    </script>-->
    <script>
        document.getElementById("toggleSidebar").addEventListener("click", function () {
            var sidebar = document.getElementById("sidebar");
            sidebar.classList.toggle("d-none");
        });
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Plyr JS -->
    <script src="https://cdn.plyr.io/3.7.8/plyr.polyfilled.js"></script>
</body>
</html>
